[user]
	name = mxaddict
	email = mxaddict@kryptic.sh
	signingkey = mxaddict@kryptic.sh
[color]
	ui = true
[core]
	excludesfile = ~/.gitignore
[pull]
	rebase = false
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[diff "gpg"]
	textconv = gpg --decrypt --quiet --batch
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential
