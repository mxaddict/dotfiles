#!/usr/bin/env bash
# vi: ft=bash
# .setup — first-run interactive wizard.
# Collects identity + Hyprland defaults, runs .update, then patches the
# seeded template destinations with the collected values.
#
# Re-running is safe: existing values are shown as defaults; pressing Enter
# keeps them. Pass --no-update to skip the .update call (just re-prompt).
set -euo pipefail

GREEN_CHECK="\e[32m✅\e[0m"
WARN_CHECK="\e[38;5;208m✅\e[0m"
INFO="\e[34mℹ\e[0m"

dotfiles="${DOTFILES_DIR:-$HOME/.files}"
config="$HOME/.config"
RUN_UPDATE=true
NON_INTERACTIVE=false

for arg in "$@"; do
    case "$arg" in
        --no-update) RUN_UPDATE=false ;;
        -y|--yes) NON_INTERACTIVE=true ;;
        -h|--help)
            cat <<EOF
Usage: $(basename "$0") [--no-update] [-y|--yes]

  --no-update  Skip the .update call (only prompt + patch).
  -y, --yes    Non-interactive: accept all defaults / existing values.

Walks you through:
  - Git identity (name, email, optional GPG signing)
  - Hyprland app defaults (terminal, file manager, lock command)
  - Keyboard layout

Then runs .update to seed templates and patches the resulting files in
\$HOME with your answers. Existing customizations are preserved when you
press Enter at a prompt.
EOF
            exit 0
            ;;
    esac
done

prompt() {
    # prompt VAR "question" "default"
    local var="$1" q="$2" def="${3:-}" input
    if [ "$NON_INTERACTIVE" = true ]; then
        printf -v "$var" '%s' "$def"
        return
    fi
    if [ -n "$def" ]; then
        read -r -p "$(printf '  %b %s [%s]: ' "$INFO" "$q" "$def")" input
    else
        read -r -p "$(printf '  %b %s: ' "$INFO" "$q")" input
    fi
    printf -v "$var" '%s' "${input:-$def}"
}

prompt_yn() {
    local var="$1" q="$2" def="${3:-n}" input
    if [ "$NON_INTERACTIVE" = true ]; then
        case "$def" in [yY]*) printf -v "$var" yes ;; *) printf -v "$var" no ;; esac
        return
    fi
    while true; do
        read -r -p "$(printf '  %b %s [%s/%s]: ' "$INFO" "$q" \
            "$([ "$def" = y ] && echo Y || echo y)" \
            "$([ "$def" = y ] && echo n || echo N)")" input
        input="${input:-$def}"
        case "$input" in
            [yY]|[yY][eE][sS]) printf -v "$var" yes; return ;;
            [nN]|[nN][oO])     printf -v "$var" no; return ;;
        esac
    done
}

# Read current value from a Hyprland variable line in a conf file.
# Falls back to provided default if the file or line is missing.
current_hypr_var() {
    local file="$1" name="$2" def="$3"
    [ -f "$file" ] || { printf '%s' "$def"; return; }
    local val
    val="$(awk -v key="\$$name" '
        $1 == key && $2 == "=" {
            sub(/^[^=]*=[ \t]*/, "")
            print
            exit
        }
    ' "$file")"
    printf '%s' "${val:-$def}"
}

current_kb_layout() {
    local file="$1" def="$2" val
    [ -f "$file" ] || { printf '%s' "$def"; return; }
    val="$(awk '/^[ \t]*kb_layout[ \t]*=/ {
        sub(/^[^=]*=[ \t]*/, "")
        print
        exit
    }' "$file")"
    printf '%s' "${val:-$def}"
}

cat <<EOF

  .files setup wizard
  ===================
  Answers fill in your local-only config. Press Enter to accept the default
  shown in brackets. Re-run any time to change values.

EOF

# Prompt targets — declared up front so shellcheck can follow assignments
# done indirectly via `printf -v` inside prompt() / prompt_yn().
git_name=""
git_email=""
git_key=""
gpg_sign="no"
term=""
fm=""
lock=""
kb=""

# --- Git identity ---
echo -e "  $GREEN_CHECK Git identity"
def_name="$(git config --get user.name 2>/dev/null || echo)"
def_email="$(git config --get user.email 2>/dev/null || echo)"
def_key="$(git config --get user.signingkey 2>/dev/null || echo)"
def_sign="$(git config --get commit.gpgsign 2>/dev/null || echo false)"
[ "$def_sign" = "true" ] && def_sign_yn=y || def_sign_yn=n

prompt git_name  "Your name"  "$def_name"
prompt git_email "Your email" "$def_email"
prompt git_key   "GPG signing key (blank to skip)" "${def_key:-$git_email}"
if [ -n "$git_key" ]; then
    prompt_yn gpg_sign "Sign all commits with this key?" "$def_sign_yn"
else
    gpg_sign=no
fi

# --- Hyprland defaults ---
echo
echo -e "  $GREEN_CHECK Hyprland defaults"
def_term="$(current_hypr_var "$config/hypr/apps.conf" terminal alacritty)"
def_fm="$(current_hypr_var "$config/hypr/apps.conf" filemanager "nautilus -w")"
def_lock="$(current_hypr_var "$config/hypr/apps.conf" lock hyprlock)"
def_kb="$(current_kb_layout "$config/hypr/input.conf" us)"

prompt term "Terminal command"     "$def_term"
prompt fm   "File manager command" "$def_fm"
prompt lock "Lock screen command"  "$def_lock"
prompt kb   "Keyboard layout"      "$def_kb"

# --- Run .update to seed templates (and install everything) ---
if [ "$RUN_UPDATE" = true ]; then
    echo
    echo -e "  $GREEN_CHECK Running .update — this seeds templates and installs packages..."
    "$dotfiles/.local/bin/.update"
fi

# --- Patch ~/.gitconfig.local ---
gcl="$HOME/.gitconfig.local"
{
    printf '[user]\n\tname = %s\n\temail = %s\n' "$git_name" "$git_email"
    [ -n "$git_key" ] && printf '\tsigningkey = %s\n' "$git_key"
    if [ "$gpg_sign" = yes ]; then
        printf '\n[commit]\n\tgpgsign = true\n'
    fi
} > "$gcl"
echo -e "  $GREEN_CHECK Wrote $gcl"

# --- Patch apps.conf ---
apps="$config/hypr/apps.conf"
if [ -f "$apps" ]; then
    # POSIX-friendly in-place edit: rewrite via temp file.
    tmp="$(mktemp)"
    awk -v term="$term" -v fm="$fm" -v lock="$lock" '
        /^\$terminal[ \t]*=/    { printf "$terminal    = %s\n", term; next }
        /^\$filemanager[ \t]*=/ { printf "$filemanager = %s\n", fm;   next }
        /^\$lock[ \t]*=/        { printf "$lock        = %s\n", lock; next }
        { print }
    ' "$apps" > "$tmp" && mv "$tmp" "$apps"
    echo -e "  $GREEN_CHECK Updated $apps"
else
    echo -e "  $WARN_CHECK $apps not found — skipped (run .update first)."
fi

# --- Patch input.conf ---
input="$config/hypr/input.conf"
if [ -f "$input" ]; then
    tmp="$(mktemp)"
    awk -v kb="$kb" '
        /^[ \t]*kb_layout[ \t]*=/ {
            match($0, /^[ \t]*/)
            indent = substr($0, 1, RLENGTH)
            printf "%skb_layout = %s\n", indent, kb
            next
        }
        { print }
    ' "$input" > "$tmp" && mv "$tmp" "$input"
    echo -e "  $GREEN_CHECK Updated $input"
else
    echo -e "  $WARN_CHECK $input not found — skipped (run .update first)."
fi

echo
echo -e "  $GREEN_CHECK Setup complete."
echo
echo "  Still want to customize manually:"
echo "    - $config/hypr/monitors.conf    (run \`hyprctl monitors\` first)"
echo "    - $config/hypr/workspaces.conf  (pin workspaces to monitors)"
echo "    - $config/hypr/hyprpaper.conf   (wallpaper path)"
echo "    - $HOME/.gitconfig.local        (anything else git-related)"
echo
echo "  Reload Hyprland with: hyprctl reload"
echo
