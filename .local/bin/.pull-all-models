#!/usr/bin/env bash

# Pull all models configured in opencode
# This script pulls all the coding models specified in your opencode configuration

echo "Pulling all models configured in opencode..."

# Extract model names from the opencode.json file
MODEL_LIST=$(jq -r '.provider.ollama.models | keys[]' "$HOME/.files/.config/opencode/opencode.json")

# Counter for progress
COUNT=0
TOTAL=$(echo "$MODEL_LIST" | wc -l)

# Pull each model
while IFS= read -r model; do
    COUNT=$((COUNT + 1))
    echo "[$COUNT/$TOTAL] Pulling $model..."
    ollama pull "$model"
done <<<"$MODEL_LIST"

echo "Finished pulling all models!"
