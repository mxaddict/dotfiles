#!/usr/bin/env bash
# vi: ft=bash
set -euo pipefail

SESSION_NAME=$(basename "$PWD")

# Attach to existing session if it exists
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    tmux attach-session -t "$SESSION_NAME"
    exit 0
fi

# Create new session with nvim in window 0
tmux new-session -d -s "$SESSION_NAME" -c "$PWD" nvim

# Create windows 1 and 2
tmux new-window -t "$SESSION_NAME" -c "$PWD"
tmux new-window -t "$SESSION_NAME" -c "$PWD"

# Select window 0 and attach
tmux select-window -t "$SESSION_NAME:0"
tmux attach-session -t "$SESSION_NAME"
